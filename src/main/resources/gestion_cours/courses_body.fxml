<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.courses.CourseListController">
    <children>
        <VBox spacing="20.0" style="-fx-background-color: transparent;">
            <children>
                
                <!-- Header Card -->
                <HBox alignment="CENTER_LEFT" styleClass="glass-card" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="My Courses" />
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748B;" text="Manage and track all your courses in one place" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onMouseClicked="#goToAddCourse" style="-fx-background-color: #004fb0; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 10;" text="+ Add a Course" />
                    </children>
                </HBox>
                
                <!-- Stats Banner -->
                <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #004fb0; -fx-background-radius: 15;">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="15.0" top="15.0" /></padding>
                            <children>
                                <Label fx:id="statTotal" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8);" text="TOTAL COURSES" />
                            </children>
                        </VBox>
                        
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="15.0" top="15.0" /></padding>
                            <children>
                                <Label fx:id="statInProgress" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8);" text="IN PROGRESS" />
                            </children>
                        </VBox>
                        
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="15.0" top="15.0" /></padding>
                            <children>
                                <Label fx:id="statCompleted" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8);" text="COMPLETED" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                
                <!-- Content Area Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                            <padding>
                                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                            </padding>
                            <children>
                                <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="Course List" />
                                <TextField fx:id="searchField" promptText="Search for a course..." style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 15;" minWidth="250.0">
                                    <HBox.margin><Insets left="20.0" /></HBox.margin>
                                </TextField>
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="statusFilter" promptText="All statuses" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 5;" />
                                <ComboBox fx:id="sortComboBox" promptText="Sort by" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 5;" />
                            </children>
                        </HBox>
                        
                        <FlowPane fx:id="coursesContainer" hgap="25.0" vgap="25.0">
                            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                        </FlowPane>
                        
                        <VBox fx:id="emptyState" alignment="CENTER" spacing="15.0" visible="false" managed="false">
                            <padding><Insets bottom="50.0" top="50.0" /></padding>
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #64748B;" text="No courses found" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>
