                                    </children>
                                </StackPane>
                                <VBox spacing="1.0">
                                    <children>
                                        <Label styleClass="studly-ai-title" text="Studly AI Assistant" />
                                        <Label styleClass="studly-ai-subtitle" text="Ask anything about your course" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="chatStatusLabel" style="-fx-text-fill: #94A3B8; -fx-font-weight: 800; -fx-font-size: 11px;" text="" />
                                <Button mnemonicParsing="false" onAction="#summarizeCoursePdf" styleClass="studly-ai-header-btn" text="Résumé" />
                                <Button mnemonicParsing="false" onAction="#minimizeChat" styleClass="studly-ai-header-btn" text="—" />
                                <Button mnemonicParsing="false" onAction="#toggleChatFullscreen" styleClass="studly-ai-header-btn" text="⤢" />
                                <Button mnemonicParsing="false" onAction="#closeChat" styleClass="studly-ai-header-btn,studly-ai-close-btn" text="✕" />
                            </children>
                        </HBox>

                        <ListView fx:id="chatListView" VBox.vgrow="ALWAYS" styleClass="studly-ai-list" />

                        <HBox spacing="10.0" styleClass="studly-ai-input-bar">
                            <children>
                                <TextField fx:id="chatInputField" HBox.hgrow="ALWAYS" promptText="Message Studly AI..."
                                           styleClass="studly-ai-input" onAction="#handleSendChat" />
                                <Button fx:id="chatSendButton" mnemonicParsing="false" onAction="#handleSendChat" styleClass="studly-ai-send" text="Send" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Button fx:id="chatFabButton" mnemonicParsing="false" onAction="#toggleChatPanel"
                        styleClass="studly-ai-fab" StackPane.alignment="BOTTOM_RIGHT">
                    <graphic>
                        <SVGPath content="M12 2a4 4 0 0 0-4 4v1H6a3 3 0 0 0-3 3v5a3 3 0 0 0 3 3h1v2a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2h1a3 3 0 0 0 3-3v-5a3 3 0 0 0-3-3h-2V6a4 4 0 0 0-4-4zm-2 5V6a2 2 0 1 1 4 0v1h-4zm-2 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm8 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" fill="WHITE" scaleX="1.05" scaleY="1.05" />
                    </graphic>
                </Button>
            </children>
        </StackPane>

        <!-- Premium Delete Modal Overlay -->
        <StackPane fx:id="deleteModalOverlay" managed="false" styleClass="modal-overlay" visible="false">
            <children>
                <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="450.0" spacing="25.0" styleClass="modal-content-detail">
                    <children>
                        <Circle fill="#FEE2E2" radius="35.0" stroke="WHITE" strokeWidth="0.0" />
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="Confirm Deletion" />
                                <Label alignment="CENTER" lineSpacing="5.0" text="Are you sure you want to delete this course? This will remove all associated content and activities. This action is irreversible." textAlignment="CENTER" wrapText="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#closeDeleteModal" prefWidth="150.0" styleClass="btn-modal-cancel" text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#confirmDelete" prefWidth="150.0" styleClass="btn-modal-delete" text="Delete Course" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
