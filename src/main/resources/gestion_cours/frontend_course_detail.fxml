                                                        <Label fx:id="noQuizLabel" style="-fx-text-fill: #94A3B8; -fx-font-style: italic; -fx-padding: 10 0;" text="No AI assessments generated yet. Use the Chat to generate one." />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- Right Column: Sidebar -->
                                <VBox maxWidth="380.0" minWidth="320.0" spacing="30.0">
