                        <Insets left="60.0" right="60.0" top="30.0" />
                    </padding>
                    <children>
                        <!-- Top Navigation Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Button mnemonicParsing="false" onMouseClicked="#goToCourses" style="-fx-background-color: white; -fx-background-radius: 50; -fx-padding: 10 24; -fx-text-fill: #64748B; -fx-font-weight: 800; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" text="←  Back to Courses" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="15.0">
                                   <children>
                                      <Label style="-fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 12px;" text="LAST UPDATED" />
                                      <Label fx:id="detailCreatedAt" style="-fx-text-fill: #475569; -fx-font-weight: 800; -fx-font-size: 12px; -fx-background-color: #F1F5F9; -fx-padding: 5 12; -fx-background-radius: 8;" text="14 Apr 2026" />
