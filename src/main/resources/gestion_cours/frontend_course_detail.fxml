                                                        <SVGPath content="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z" fill="#0059A9" />
                                                        <Label styleClass="section-title" text="Learning Materials" />
                                                    </children>
                                                </HBox>
                                                
                                                <VBox spacing="15.0">
                                                    <children>
                                                        <!-- External Link Widget -->
                                                        <HBox fx:id="resourceLinkBox" alignment="CENTER_LEFT" spacing="20.0" styleClass="resource-tile-detail">
                                                            <children>
                                                                <StackPane style="-fx-background-color: #ECFDF5; -fx-background-radius: 12; -fx-padding: 15;">
                                                                   <children>
                                                                      <SVGPath content="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" fill="#10B981" scaleX="1.2" scaleY="1.2" />
                                                                   </children>
                                                                </StackPane>
                                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label style="-fx-font-weight: 900; -fx-text-fill: #0F172A; -fx-font-size: 14px;" text="External Reference" />
                                                                        <Label fx:id="resourceLinkLabel" style="-fx-text-fill: #6366F1; -fx-font-weight: bold;" text="https://docs.oracle.com/java" />
                                                                    </children>
                                                                </VBox>
                                                                <SVGPath content="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" fill="#94A3B8" />
                                                            </children>
                                                        </HBox>

                                                        <!-- Course file attachment -->
                                                        <VBox fx:id="filePreviewBox" spacing="0.0" style="-fx-border-color: #CBD5E1; -fx-border-radius: 16; -fx-background-radius: 16; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,51,102,0.12), 20, 0, 0, 6);">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-background-color: linear-gradient(to right, #1E293B, #334155); -fx-background-radius: 16 16 0 0; -fx-padding: 14 20;">
                                                                    <children>
                                                                        <StackPane fx:id="fileTypeBadge" alignment="CENTER" minWidth="48.0" prefWidth="48.0" prefHeight="48.0" style="-fx-background-color: #64748B; -fx-background-radius: 12;">
                                                                           <children>
                                                                              <Label fx:id="fileTypeBadgeLabel" style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11px;" text="FILE" />
                                                                           </children>
                                                                        </StackPane>
                                                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                                           <children>
                                                                              <Label style="-fx-font-size: 9px; -fx-font-weight: 900; -fx-text-fill: #94A3B8; -fx-letter-spacing: 0.12em;" text="COURSE FILE" />
