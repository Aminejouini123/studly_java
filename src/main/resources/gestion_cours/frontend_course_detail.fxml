                                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                    <children>
                                                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" fill="#6366F1" scaleX="1.2" scaleY="1.2" />
                                                        <VBox spacing="2">
                                                            <children>
                                                                <Label styleClass="section-title" text="AI Assessments &amp; Quizzes" />
