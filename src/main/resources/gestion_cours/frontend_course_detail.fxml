                                                            <children>
                                                                <Label styleClass="meta-label-detail" text="Complexity" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label styleClass="meta-value-detail" style="-fx-background-color: #FEF2F2; -fx-text-fill: #EF4444;" text="High" />
                                                            </children>
                                                        </HBox>
