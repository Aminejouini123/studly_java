                                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <FlowPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Label fx:id="detailType" styleClass="badge-pill-detail" text="PRACTICAL" />
                                                <Label fx:id="detailStatus" styleClass="badge-pill-detail" text="IN PROGRESS" />
                                                <Label fx:id="detailDifficulty" styleClass="badge-pill-detail" text="MEDIUM" />
                                                <Label fx:id="detailPriority" styleClass="badge-pill-detail" text="HIGH" />
                                            </children>
                                        </FlowPane>
                                        <VBox spacing="5.0">
                                            <children>

                                                <Label fx:id="detailTitle" styleClass="hero-title-detail" text="Advanced Java Programming" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <HBox spacing="40.0">
                                            <children>
                                                <HBox alignment="CENTER" spacing="12.0">
                                                   <children>
                                                      <SVGPath content="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z" fill="WHITE" opacity="0.8" scaleX="1.1" scaleY="1.1" />
                                                      <VBox>
                                                         <children>
                                                            <Label style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px; -fx-font-weight: 800;" text="DURATION" />
                                                            <Label fx:id="detailDuration" styleClass="hero-info-pill" style="-fx-font-weight: 800;" text="12 hours" />
                                                         </children>
                                                      </VBox>
                                                   </children>
                                                </HBox>
                                                <HBox alignment="CENTER" spacing="12.0">
                                                   <children>
                                                      <SVGPath content="M12 3L1 9l11 6l9-4.91V17h2V9L12 3zM5 13.18v2.81l7 3.82l7-3.82v-2.81l-7 3.82l-7-3.82z" fill="WHITE" opacity="0.8" scaleX="1.1" scaleY="1.1" />
                                                      <VBox>
                                                         <children>
                                                            <Label style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px; -fx-font-weight: 800;" text="ACADEMIC TERM" />
                                                            <Label fx:id="detailSemester" styleClass="hero-info-pill" style="-fx-font-weight: 800;" text="Semester 1" />
                                                         </children>
                                                      </VBox>
                                                   </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
