                                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEditAction" styleClass="sidebar-action-btn" text="✎   Modify Details" />
                                                        <Button alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: #EEF2FF; -fx-text-fill: #4F46E5;" styleClass="sidebar-action-btn" text="📂  View Folders" />
                                                        <Button alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToExams" style="-fx-background-color: #F5F3FF; -fx-text-fill: #7C3AED;" styleClass="sidebar-action-btn" text="🎓  Manage Exams" />
                                                        <Separator style="-fx-opacity: 0.5;">
