                                                           </padding>
                                                        </Separator>
                                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openDeleteModal" styleClass="sidebar-action-btn, sidebar-action-btn-delete" text="🗑   Remove Course" />
