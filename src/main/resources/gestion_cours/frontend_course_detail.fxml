                                                        <Label styleClass="section-title" text="Course Overview &amp; Notes" />
                                                    </children>
                                                </HBox>
                                                <Label fx:id="detailComment" lineSpacing="6.0" style="-fx-text-fill: #475569; -fx-font-size: 15px; -fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-padding: 25; -fx-border-color: #E2E8F0; -fx-border-radius: 12;" text="Detailed course notes and additional information will appear here once populated. This section is designed to hold extended descriptions and instructional guidance." wrapText="true" />
                                            </children>
                                        </VBox>

                                        <!-- Learning Materials -->
                                        <VBox spacing="20.0" styleClass="glass-card" style="-fx-padding: 30;">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="15.0">
