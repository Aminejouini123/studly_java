<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" prefHeight="800.0" prefWidth="1100.0" styleClass="root" stylesheets="@../TEMPLATE/frontend_style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.courses.CourseListController">
   
   <BorderPane prefHeight="800.0" prefWidth="1100.0">
      <top>
         <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="top-bar" BorderPane.alignment="CENTER">
            <padding>
               <Insets left="30.0" right="30.0" />
            </padding>
            <children>
               <!-- Logo -->
               <Label styleClass="brand-text" text="studly" textFill="#4b5ed4">
                  <HBox.margin>
                     <Insets right="40.0" />
                  </HBox.margin>
               </Label>
               
               <!-- Navigation Links -->
               <HBox alignment="CENTER_LEFT" spacing="25.0">
                  <children>
                     <Label fx:id="navDashboard" onMouseClicked="#goToDashboard" styleClass="nav-link" text="Dashboard" />
                     <Label onMouseClicked="#goToPlanning" styleClass="nav-link" text="Planning" />
                     <Label fx:id="navCourses" styleClass="nav-link-active" text="Courses" />
                     <Label styleClass="nav-link" text="Groups" />
                     <Label styleClass="nav-link" text="Tasks" />
                  </children>
               </HBox>
               
               <Region HBox.hgrow="ALWAYS" />
               
               <!-- Search & Actions -->
               <HBox alignment="CENTER" spacing="20.0">
                  <children>
                     <!-- Notifications -->
                     <Region maxHeight="24.0" maxWidth="24.0" minHeight="24.0" minWidth="24.0" prefHeight="24.0" prefWidth="24.0" style="-fx-shape: 'M 12 22 c 1.1 0 2 -0.9 2 -2 h -4 c 0 1.1 0.9 2 2 2 Z m 6 -6 v -5 c 0 -3.07 -1.63 -5.64 -4.5 -6.32 V 4 c 0 -0.83 -0.67 -1.5 -1.5 -1.5 s -1.5 0.67 -1.5 1.5 v 0.68 C 7.64 5.36 6 7.92 6 11 v 5 l -2 2 v 1 h 16 v -1 l -2 -2 Z'; -fx-background-color: #64748B; -fx-cursor: hand;" />
                     
                     <Button mnemonicParsing="false" styleClass="btn-primary" text="Create New" />
                     
                     <!-- Profile Image -->
                     <Circle fill="#b9b7b2" radius="16.0" stroke="#334155" strokeWidth="1.5" />
                  </children>
               </HBox>
            </children>
         </HBox>
      </top>
      
      <center>
         <!-- Main Content Area -->
         <ScrollPane fitToWidth="true" style="-fx-padding: 0;" styleClass="scroll-pane" BorderPane.alignment="CENTER">
            <content>
               <VBox spacing="20.0" style="-fx-background-color: transparent;">
                  <padding>
                     <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
                  </padding>
                  <children>
                     
                     <!-- Header Card -->
                     <HBox alignment="CENTER_LEFT" styleClass="glass-card">
                        <padding>
                           <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                        </padding>
                        <children>
                           <VBox spacing="5.0">
                              <children>
                                 <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="My Courses" />
                                 <Label style="-fx-font-size: 13px; -fx-text-fill: #64748B;" text="Manage and track all your courses in one place" />
                              </children>
                           </VBox>
                           <Region HBox.hgrow="ALWAYS" />
                           <Button mnemonicParsing="false" onMouseClicked="#goToAddCourse" styleClass="btn-primary" text="+ Add a Course" />
                        </children>
                     </HBox>
                     
                     <!-- Stats Banner -->
                     <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #004fb0; -fx-background-radius: 12;" VBox.vgrow="NEVER">
                        <padding>
                           <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                        </padding>
                        <children>
                           <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                              <padding><Insets bottom="15.0" top="15.0" /></padding>
                              <children>
                                 <Label fx:id="statTotal" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                 <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8); -fx-letter-spacing: 1px;" text="TOTAL COURSES" />
                              </children>
                           </VBox>
                           
                           <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                              <padding><Insets bottom="15.0" top="15.0" /></padding>
                              <children>
                                 <Label fx:id="statInProgress" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                 <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8); -fx-letter-spacing: 1px;" text="IN PROGRESS" />
                              </children>
                           </VBox>
                           
                           <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                              <padding><Insets bottom="15.0" top="15.0" /></padding>
                              <children>
                                 <Label fx:id="statCompleted" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                 <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8); -fx-letter-spacing: 1px;" text="COMPLETED" />
                              </children>
                           </VBox>
                           
                           <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                              <padding><Insets bottom="15.0" top="15.0" /></padding>
                              <children>
                                 <Label fx:id="statPending" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="0" />
                                 <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.8); -fx-letter-spacing: 1px;" text="PENDING" />
                              </children>
                           </VBox>
                        </children>
                     </HBox>
                     
                     <!-- Content Area Card -->
                     <VBox styleClass="glass-card" VBox.vgrow="ALWAYS">
                        <children>
                           <!-- Tools Row -->
                           <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                              <padding>
                                 <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                              </padding>
                              <children>
                                 <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="Course List" />
                                 
                                 <TextField fx:id="searchField" promptText="Search for a course..." styleClass="search-field" minWidth="250.0">
                                    <HBox.margin>
                                       <Insets left="20.0" />
                                    </HBox.margin>
                                 </TextField>
                                 
                                 <ComboBox fx:id="statusFilter" promptText="All statuses" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 5; -fx-padding: 2 10;" minWidth="150.0">
                                    <items>
                                       <FXCollections fx:factory="observableArrayList">
                                          <String fx:value="All statuses" />
                                          <String fx:value="In Progress" />
                                          <String fx:value="Completed" />
                                          <String fx:value="Pending" />
                                       </FXCollections>
                                    </items>
                                 </ComboBox>
                                 
                                 <ComboBox fx:id="sortComboBox" promptText="Sort by" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 5; -fx-padding: 2 10;" minWidth="150.0">
                                    <items>
                                       <FXCollections fx:factory="observableArrayList">
                                          <String fx:value="Name (A-Z)" />
                                          <String fx:value="Coefficient (High-Low)" />
                                          <String fx:value="Semester (1-2)" />
                                          <String fx:value="Duration (Shortest)" />
                                       </FXCollections>
                                    </items>
                                 </ComboBox>
                              </children>
                           </HBox>
                           
                            <!-- Course List Container -->
                            <FlowPane fx:id="coursesContainer" hgap="25.0" vgap="25.0">
                               <padding>
                                  <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                               </padding>
                            </FlowPane>
                            
                            <!-- Empty State -->
                            <VBox fx:id="emptyState" alignment="CENTER" spacing="15.0" style="-fx-border-color: #E2E8F0; -fx-border-style: dashed; -fx-border-radius: 8; -fx-border-width: 2; -fx-background-color: #FAFAFA; -fx-background-radius: 8;">
                               <padding>
                                  <Insets bottom="80.0" left="20.0" right="20.0" top="80.0" />
                               </padding>
                               <VBox.margin>
                                  <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                               </VBox.margin>
                               <children>
                                  <!-- Book Icon -->
                                  <Region maxHeight="60.0" maxWidth="60.0" minHeight="60.0" minWidth="60.0" prefHeight="60.0" prefWidth="60.0" style="-fx-shape: 'M 4 6 h 16 v 16 c 0 1.1 -0.9 2 -2 2 H 4 c -1.1 0 -2 -0.9 -2 -2 V 8 c 0 -1.1 0.9 -2 2 -2 Z m 10 0 c 0 -1.1 0.9 -2 2 -2 h 4 c 1.1 0 2 0.9 2 2 v 16 c 0 1.1 -0.9 2 -2 2 h -4 c -1.1 0 -2 -0.9 -2 -2 Z'; -fx-background-color: #004fb0; -fx-opacity: 0.1;" StackPane.alignment="CENTER" />
                                  <StackPane>
                                       <Region maxHeight="40.0" maxWidth="40.0" minHeight="40.0" minWidth="40.0" prefHeight="40.0" prefWidth="40.0" style="-fx-shape: 'M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z'; -fx-background-color: #004fb0; -fx-translate-y: -75;" />
                                       <Circle fill="transparent" radius="40" stroke="#004fb0" strokeWidth="2" style="-fx-opacity: 0.2; -fx-translate-y: -75;" />
                                  </StackPane>
                                  <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #0F172A; -fx-translate-y: -30;" text="No courses found" />
                                  <Label alignment="CENTER" maxWidth="350.0" style="-fx-font-size: 13px; -fx-text-fill: #64748B; -fx-text-alignment: center; -fx-translate-y: -30;" text="You haven't added any courses yet. Start your learning journey now!" textAlignment="CENTER" wrapText="true" />
                                  <Button mnemonicParsing="false" onMouseClicked="#goToAddCourse" styleClass="btn-primary" style="-fx-padding: 10 25; -fx-translate-y: -15;" text="+ Add my first course" />
                               </children>
                            </VBox>
                        </children>
                     </VBox>
                     
                  </children>
               </VBox>
            </content>
         </ScrollPane>
      </center>
   </BorderPane>
</StackPane>
