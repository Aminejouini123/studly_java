<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" stylesheets="@../TEMPLATE/backend_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.activities.ActivityEditController">
    <children>
        <VBox styleClass="admin-form-container" maxWidth="900.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="admin-form-section-title" text="Edit Instructional Activity" />
                                <Label styleClass="subtitle-text" text="Modify the pedagogical parameters and instructions for this record." />
                            </children>
                        </VBox>
                        <Button onAction="#handleBack" styleClass="btn-secondary" text="Discard Changes" />
                    </children>
                </HBox>

                <Region prefHeight="10.0" />

                <!-- 1. Identification -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="ACTIVITY CORE DETAILS" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Activity Title" styleClass="admin-form-label" />
                                        <TextField fx:id="titleField" styleClass="admin-form-input" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" prefWidth="250.0">
                                    <children>
                                        <Label text="Activity Type" styleClass="admin-form-label" />
                                        <ComboBox fx:id="typeComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 2. Academic Mapping -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="MAPPING &amp; DIFFICULTY" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Difficulty" styleClass="admin-form-label" />
                                        <ComboBox fx:id="difficultyComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Level" styleClass="admin-form-label" />
                                        <ComboBox fx:id="levelComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Status" styleClass="admin-form-label" />
                                        <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 3. Instructions & Content -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="PEDAGOGICAL CONTENT" styleClass="admin-form-label" />
                        <VBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Instructions" styleClass="admin-form-label" />
                                        <TextArea fx:id="instructionsArea" prefRowCount="3" styleClass="admin-form-input" wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Expected Output" styleClass="admin-form-label" />
                                                <TextArea fx:id="outputArea" prefRowCount="2" styleClass="admin-form-input" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Hints" styleClass="admin-form-label" />
                                                <TextArea fx:id="hintsArea" prefRowCount="2" styleClass="admin-form-input" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Actions -->
                <HBox styleClass="admin-form-button-bar">
                    <children>
                        <Button fx:id="updateBtn" onAction="#handleUpdateActivity" styleClass="btn-primary" text="💾 Update Record" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
