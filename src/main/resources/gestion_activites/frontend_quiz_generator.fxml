<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.activities.QuizController"
           styleClass="ai-dark-theme" stylesheets="@../TEMPLATE/frontend_style.css">

    <BorderPane>
        <!-- FUTURISTIC NAVIGATION BAR -->
        <top>
            <HBox alignment="CENTER_LEFT" spacing="25" style="-fx-padding: 25 60; -fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                <children>
                    <StackPane alignment="CENTER">
                        <Circle radius="22" fill="#6366F1" style="-fx-effect: dropshadow(three-pass-box, #6366F1, 15, 0, 0, 0);"/>
                        <SVGPath content="M12 2a4 4 0 0 0-4 4v1H6a3 3 0 0 0-3 3v5a3 3 0 0 0 3 3h1v2a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2h1a3 3 0 0 0 3-3v-5a3 3 0 0 0-3-3h-2V6a4 4 0 0 0-4-4z" fill="white" scaleX="0.8" scaleY="0.8"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Studly AI" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: white; -fx-letter-spacing: 0.5px;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="NEURAL ENGINE v4.0" style="-fx-text-fill: #818CF8; -fx-font-weight: 900; -fx-font-size: 10px; -fx-letter-spacing: 2px;"/>
                            <Circle radius="2" fill="#4ADE80" style="-fx-effect: dropshadow(three-pass-box, #4ADE80, 5, 0, 0, 0);"/>
                            <Label text="System Ready" style="-fx-text-fill: #4ADE80; -fx-font-weight: 800; -fx-font-size: 10px;"/>
                        </HBox>
                    </VBox>
                    <Button text="Terminate Session" onAction="#handleBack" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 12; -fx-text-fill: #94A3B8; -fx-font-weight: 800; -fx-padding: 10 25; -fx-cursor: hand;"/>
                </children>
            </HBox>
        </top>

        <center>
            <StackPane>
                <padding><Insets top="50" left="80" right="80" bottom="50"/></padding>
                <children>
                    <!-- CONFIGURATION INTERFACE -->
                    <HBox fx:id="configPane" spacing="0" maxWidth="1100" maxHeight="650" styleClass="glass-card-dark" style="-fx-overflow: hidden;">
                        <children>
                            <!-- LEFT DESIGN PANEL -->
                            <VBox spacing="40" prefWidth="360" styleClass="sidebar-dark">
                                <children>
                                    <VBox spacing="15">
                                        <Label text="AI Setup" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                                        <Label text="Configure the neural parameters to synthesize a high-fidelity assessment from your course material." wrapText="true" style="-fx-text-fill: #94A3B8; -fx-font-size: 14px; -fx-line-spacing: 5;"/>
                                    </VBox>
                                    
                                    <VBox spacing="25">
                                        <VBox spacing="8">
                                            <HBox spacing="15" alignment="CENTER_LEFT">
                                                <Circle radius="4" fill="#6366F1"/>
                                                <Label text="Deep Semantic Scan" style="-fx-text-fill: #E2E8F0; -fx-font-weight: 800; -fx-font-size: 12px;"/>
                                            </HBox>
                                            <Label text="Analyzes core concepts and relationships." style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-padding: 0 0 0 34;"/>
                                        </VBox>
                                        <VBox spacing="8">
                                            <HBox spacing="15" alignment="CENTER_LEFT">
                                                <Circle radius="4" fill="#A855F7"/>
                                                <Label text="Synthetic Item Generation" style="-fx-text-fill: #E2E8F0; -fx-font-weight: 800; -fx-font-size: 12px;"/>
                                            </HBox>
                                            <Label text="Creates unique, non-repetitive questions." style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-padding: 0 0 0 34;"/>
                                        </VBox>
                                    </VBox>
                                    
                                    <Region VBox.vgrow="ALWAYS"/>
                                    
                                    <VBox spacing="10" style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-padding: 20; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05);">
                                        <Label text="CURRENT CONTEXT" style="-fx-text-fill: #6366F1; -fx-font-weight: 900; -fx-font-size: 10px; -fx-letter-spacing: 1.5px;"/>
                                        <Label fx:id="courseLabel" text="Loading..." style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 15px;"/>
                                    </VBox>
                                </children>
                            </VBox>

                            <!-- RIGHT SPECIFICATIONS FORM -->
                            <VBox spacing="35" HBox.hgrow="ALWAYS" style="-fx-padding: 50 60;">
                                <children>
                                    <VBox spacing="8">
                                        <Label text="Synthesis Specifications" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                                        <Label text="Fine-tune the output quality and depth." style="-fx-text-fill: #64748B; -fx-font-size: 14px;"/>
                                    </VBox>

                                    <GridPane hgap="40" vgap="25">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="100"/>
                                        </columnConstraints>

                                        <VBox spacing="10" GridPane.rowIndex="0">
                                            <Label text="ACTIVITY IDENTITY" styleClass="input-label-dark"/>
                                            <TextField fx:id="activityNameField" promptText="Assessment Title" styleClass="modern-input-dark"/>
                                        </VBox>

                                        <HBox spacing="25" GridPane.rowIndex="1">
                                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                                <Label text="NEURAL LOAD (COUNT)" styleClass="input-label-dark"/>
                                                <Spinner fx:id="questionsSpinner" maxWidth="Infinity" styleClass="modern-spinner" style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-border-color: rgba(255,255,255,0.1);"/>
                                            </VBox>
                                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                                <Label text="COMPLEXITY LEVEL" styleClass="input-label-dark"/>
                                                <ComboBox fx:id="difficultyCombo" maxWidth="Infinity" styleClass="modern-combo" style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-border-color: rgba(255,255,255,0.1);"/>
                                            </VBox>
                                        </HBox>

                                        <VBox spacing="10" GridPane.rowIndex="2">
                                            <Label text="SYNTHESIS FORMAT" styleClass="input-label-dark"/>
                                            <ComboBox fx:id="typeCombo" maxWidth="Infinity" styleClass="modern-combo" style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-border-color: rgba(255,255,255,0.1);"/>
                                        </VBox>

                                        <VBox spacing="10" GridPane.rowIndex="3">
                                            <Label text="KNOWLEDGE ANCHOR (TOPIC)" styleClass="input-label-dark"/>
                                            <TextField fx:id="topicField" promptText="Focus area..." styleClass="modern-input-dark"/>
                                        </VBox>
                                    </GridPane>

                                    <Region VBox.vgrow="ALWAYS"/>

                                    <HBox spacing="25" alignment="CENTER_RIGHT">
                                        <children>
                                            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #818CF8; -fx-font-weight: 800; -fx-font-size: 13px;"/>
                                            <Button fx:id="generateBtn" text="Initiate Generation" onAction="#handleGenerate" styleClass="btn-ai-glow" style="-fx-padding: 18 45; -fx-font-size: 16px;"/>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- QUIZ INTERFACE (DARK) -->
                    <VBox fx:id="quizPane" visible="false" managed="false" spacing="35" maxWidth="900" styleClass="glass-card-dark" style="-fx-padding: 50;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="25">
                                <children>
                                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                                        <Label fx:id="quizTitleLabel" text="Active Assessment" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                                        <Label fx:id="progressLabel" text="ANALYZING QUESTION 1" style="-fx-text-fill: #818CF8; -fx-font-weight: 900; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                                    </VBox>
                                    <HBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(74, 222, 128, 0.1); -fx-padding: 10 20; -fx-background-radius: 30; -fx-border-color: rgba(74, 222, 128, 0.3);">
                                        <Circle radius="4" fill="#4ADE80" style="-fx-effect: dropshadow(three-pass-box, #4ADE80, 10, 0, 0, 0);"/>
                                        <Label text="AI LIVE" style="-fx-text-fill: #4ADE80; -fx-font-weight: 900; -fx-font-size: 11px;"/>
                                    </HBox>
                                </children>
                            </HBox>
                            
                            <ProgressBar fx:id="progressBar" prefWidth="2000" progress="0.1" prefHeight="12" style="-fx-accent: #6366F1; -fx-control-inner-background: rgba(15, 23, 42, 0.5);"/>

                            <VBox spacing="30" style="-fx-background-color: rgba(15, 23, 42, 0.4); -fx-background-radius: 20; -fx-padding: 45; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 20;">
                                <children>
                                    <Label fx:id="questionPromptLabel" text="Synthesis Question" wrapText="true" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-line-spacing: 6; -fx-text-fill: white;"/>
                                    <VBox fx:id="answersBox" spacing="16"/>
                                </children>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="25">
                                <children>
                                    <Label fx:id="feedbackLabel" text="" wrapText="true" HBox.hgrow="ALWAYS" style="-fx-text-fill: #94A3B8; -fx-font-weight: 700; -fx-font-size: 15px;"/>
                                    <Button fx:id="nextBtn" text="Confirm Selection" onAction="#handleNext" styleClass="btn-ai-glow" disable="true" style="-fx-padding: 15 35;"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- RESULT ANALYTICS (DARK) -->
                    <VBox fx:id="resultPane" visible="false" managed="false" spacing="45" maxWidth="650" alignment="CENTER" styleClass="glass-card-dark" style="-fx-padding: 70;">
                        <children>
                            <VBox alignment="CENTER" spacing="25">
                                <StackPane>
                                    <Circle radius="50" fill="rgba(74, 222, 128, 0.1)" style="-fx-effect: dropshadow(three-pass-box, rgba(74, 222, 128, 0.4), 30, 0, 0, 0);"/>
                                    <SVGPath content="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" fill="#4ADE80" scaleX="4.5" scaleY="4.5"/>
                                </StackPane>
                                <VBox spacing="8" alignment="CENTER">
                                    <Label text="Synthesis Complete" style="-fx-font-size: 30px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                                    <Label text="Your knowledge retention metrics have been generated." style="-fx-text-fill: #94A3B8; -fx-font-size: 15px;"/>
                                </VBox>
                            </VBox>

                            <HBox spacing="60" alignment="CENTER" style="-fx-background-color: rgba(15, 23, 42, 0.3); -fx-padding: 30; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.05);">
                                <VBox alignment="CENTER" spacing="12">
                                    <Label fx:id="scoreLabel" text="8 / 10" style="-fx-font-size: 56px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                                    <Label text="RAW SCORE" styleClass="input-label-dark"/>
                                </VBox>
                                <Separator orientation="VERTICAL" style="-fx-max-height: 60; -fx-opacity: 0.1;"/>
                                <VBox alignment="CENTER" spacing="12">
                                    <Label fx:id="percentLabel" text="80%" style="-fx-font-size: 56px; -fx-font-weight: 900; -fx-text-fill: #818CF8;"/>
                                    <Label text="MASTERY LEVEL" styleClass="input-label-dark"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="20" alignment="CENTER">
                                <children>
                                    <Button text="Exit to Dashboard" onAction="#handleBack" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 12; -fx-text-fill: #94A3B8; -fx-font-weight: 800; -fx-padding: 15 30; -fx-cursor: hand;"/>
                                    <Button text="Restart Assessment" onAction="#handleRetry" styleClass="btn-ai-glow" style="-fx-padding: 15 40;"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </StackPane>
        </center>
    </BorderPane>
</StackPane>
