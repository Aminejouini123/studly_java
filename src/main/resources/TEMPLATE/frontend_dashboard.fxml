<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="800.0" prefWidth="1100.0" styleClass="root" stylesheets="@frontend_style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FrontendController">
   
   <!-- Main interface (z-index 1) -->

   <!-- Main Application Interface (z-index 1) -->
   <BorderPane prefHeight="800.0" prefWidth="1100.0">
      <top>
         <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="top-bar" BorderPane.alignment="CENTER">
            <padding>
               <Insets left="30.0" right="30.0" />
            </padding>
            <children>
               <!-- Logo -->
               <Label styleClass="brand-text" text="studly" textFill="#4b5ed4">
                  <HBox.margin>
                     <Insets right="40.0" />
                  </HBox.margin>
               </Label>
               
               <!-- Navigation Links -->
               <HBox alignment="CENTER_LEFT" spacing="25.0">
                  <children>
                     <Label onMouseClicked="#goToDashboard" styleClass="nav-link-active" text="Dashboard" />
                     <Label styleClass="nav-link" text="Planing" />
                     <Label onMouseClicked="#goToCourses" styleClass="nav-link" text="Coursses" />
                     <Label styleClass="nav-link" text="Groups" />
                     <Label styleClass="nav-link" text="Tasks" />
                  </children>
               </HBox>
               
               <Region HBox.hgrow="ALWAYS" />
               
               <!-- Search & Actions -->
               <HBox alignment="CENTER" spacing="20.0">
                  <children>
                     
                     <!-- Notifications -->
                     <Region maxHeight="24.0" maxWidth="24.0" minHeight="24.0" minWidth="24.0" prefHeight="24.0" prefWidth="24.0" style="-fx-shape: 'M 12 22 c 1.1 0 2 -0.9 2 -2 h -4 c 0 1.1 0.9 2 2 2 Z m 6 -6 v -5 c 0 -3.07 -1.63 -5.64 -4.5 -6.32 V 4 c 0 -0.83 -0.67 -1.5 -1.5 -1.5 s -1.5 0.67 -1.5 1.5 v 0.68 C 7.64 5.36 6 7.92 6 11 v 5 l -2 2 v 1 h 16 v -1 l -2 -2 Z'; -fx-background-color: #64748B; -fx-cursor: hand;" />
                     
                     <Button mnemonicParsing="false" styleClass="btn-primary" text="Create New" />
                     
                     <!-- Profile Image -->
                     <Circle fill="#b9b7b2" radius="16.0" stroke="#334155" strokeWidth="1.5" />
                  </children>
               </HBox>
            </children>
         </HBox>
      </top>
      
      <center>
         <!-- Wrapping ScrollPane so the background gradients show through -->
         <ScrollPane fitToWidth="true" style="-fx-padding: 0;" styleClass="scroll-pane" BorderPane.alignment="CENTER">
            <content>
               <VBox spacing="40.0" style="-fx-background-color: transparent;">
                  <padding>
                     <Insets bottom="50.0" left="40.0" right="40.0" top="40.0" />
                  </padding>
                  <children>
                     <!-- Dashboard blank canvas -->
                  </children>
               </VBox>
            </content>
         </ScrollPane>
      </center>
   </BorderPane>

</StackPane>
