<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="716.0" prefWidth="774.0" spacing="30.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.BackendTimeController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="title-text" text="Time Management" />
                </VBox>
                <Button onAction="#handleAddEvent" prefHeight="38.0" styleClass="btn-primary" text=" + Add Event" />
            </children>
        </HBox>

        <!-- Stat Cards Grid -->
        <HBox spacing="20.0">
            <children>
                <VBox prefHeight="130.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2C11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z" fill="#38bdf8" />
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <VBox spacing="2.0">
                            <children>
                                <Label fx:id="totalEventsLabel" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-label" text="TOTAL EVENTS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox prefHeight="130.0" spacing="15.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <SVGPath content="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z" fill="#f43f5e" scaleX="0.8" scaleY="0.8" />
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <VBox spacing="2.0">
                            <children>
                                <Label fx:id="pendingEventsLabel" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-label" text="PENDING EVENTS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <HBox alignment="CENTER_LEFT" prefHeight="0.0" prefWidth="546.0" styleClass="search-field">
            <children>
                <SVGPath content="M 15.5 14 h -0.79 l -0.28 -0.27 C 15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3 5.91 3 3 5.91 3 9.5 3 13.09 5.91 16 9.5 16 c 1.61 0 3.09 -0.59 4.23 -1.57 l 0.27 0.28 v 0.79 l 5 4.99 L 20.49 19 l -4.99 -5 Z m -6 0 C 7.01 14 5 11.99 5 9.5 5 7.01 7.01 5 9.5 5 11.99 5 14 7.01 14 9.5 14 11.99 11.99 14 9.5 14 Z" fill="#64748B" />
                <TextField fx:id="searchField" prefHeight="0.0" prefWidth="378.0" promptText="Search events..." style="-fx-background-color: transparent; -fx-text-fill: black;" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <VBox maxWidth="1.7976931348623157E308" prefHeight="386.0" prefWidth="694.0" styleClass="table-container" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                    <children>
                        <Label fx:id="scheduleLabel" styleClass="filter-text-active" text="SCHEDULE" />
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <TableView fx:id="eventsTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colTitle" minWidth="200.0" text="EVENT" />
                        <TableColumn fx:id="colDate" minWidth="100.0" text="DATE" />
                        <TableColumn fx:id="colType" minWidth="100.0" text="TYPE" />
                        <TableColumn fx:id="colDuration" minWidth="80.0" text="DURATION" />
                        <TableColumn fx:id="colPriority" minWidth="120.0" text="STATUS/PRIORITY" />
                        <TableColumn fx:id="colMotivation" minWidth="120.0" text="MOTIVATION" />
                        <TableColumn fx:id="colActions" prefWidth="130.0" resizable="false" text="ACTIONS" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
