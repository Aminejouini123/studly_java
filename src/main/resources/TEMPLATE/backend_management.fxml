<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<StackPane prefHeight="800.0" prefWidth="1100.0" styleClass="root" stylesheets="@backend_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.BackendController">

   <BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: transparent;">
      
      <!-- Left Sidebar -->
      <left>
         <VBox prefWidth="250.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
               <VBox alignment="CENTER_LEFT" spacing="5.0">
                  <padding>
                     <Insets bottom="40.0" left="25.0" right="20.0" top="30.0" />
                  </padding>
                  <children>
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <children>
                           <VBox>
                               <Label styleClass="brand-text" text="STUDLY" />
                               <Label styleClass="brand-subtitle" />
                           </VBox>
                        </children>
                     </HBox>
                  </children>
               </VBox>

               <VBox spacing="10.0">
                  <children>
                     <Button fx:id="overviewBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#showOverview" styleClass="nav-button" text="  OVERVIEW">
                        <graphic>
                           <SVGPath content="M 4 4 L 10 4 L 10 10 L 4 10 Z M 14 4 L 20 4 L 20 10 L 14 10 Z M 4 14 L 10 14 L 10 20 L 4 20 Z M 14 14 L 20 14 L 20 20 L 14 20 Z" fill="TRANSPARENT" stroke="#64748B" strokeWidth="1.5" />
                        </graphic>
                     </Button>
                     <Button fx:id="usersBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#showUsers" styleClass="nav-button-active" text="  USERS">
                        <graphic>
                           <SVGPath content="M 12 12 C 14.21 12 16 10.21 16 8 C 16 5.79 14.21 4 12 4 C 9.79 4 8 5.79 8 8 C 8 10.21 9.79 12 12 12 Z M 12 14 C 9.33 14 4 15.34 4 18 L 4 20 L 20 20 L 20 18 C 20 15.34 14.67 14 12 14 Z" fill="#38bdf8" />
                        </graphic>
                     </Button>
                     <Button fx:id="timeBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#showTimeManagement" styleClass="nav-button" text="  TIME MANAGEMENT">
                        <graphic>
                           <SVGPath content="M12,2C6.5,2,2,6.5,2,12s4.5,10,10,10s10-4.5,10-10S17.5,2,12,2z M16.2,16.2L11,13V7h1.5v5.2l4.5,2.8L16.2,16.2z" fill="#64748B" />
                        </graphic>
                     </Button>
                     <Button fx:id="coursesBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleShowCourses" styleClass="nav-button" text="  COURSES">
                        <graphic>
                           <SVGPath content="M 4 6 h 16 v 16 c 0 1.1 -0.9 2 -2 2 H 4 c -1.1 0 -2 -0.9 -2 -2 V 8 c 0 -1.1 0.9 -2 2 -2 Z m 10 0 c 0 -1.1 0.9 -2 2 -2 h 4 c 1.1 0 2 0.9 2 2 v 16 c 0 1.1 -0.9 2 -2 2 h -4 c -1.1 0 -2 -0.9 -2 -2 Z" fill="TRANSPARENT" scaleX="0.9" scaleY="0.9" stroke="#64748B" strokeWidth="1.5" />
                        </graphic>
                     </Button>
                  </children>
               </VBox>
            </children>
         </VBox>
      </left>
      
      <!-- Main Content Area -->
      <center>
         <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
            <children>
               <!-- Top App Bar -->
               <HBox alignment="CENTER_LEFT" prefHeight="61.0" spacing="20.0" styleClass="top-bar">
                  <padding>
                     <Insets left="30.0" right="30.0" />
                  </padding>
                  <children>
                     <Region HBox.hgrow="ALWAYS" />
                     <HBox alignment="CENTER" spacing="12.0">
                        <children>
                            <VBox alignment="CENTER_RIGHT">
                                <Label style="-fx-text-fill: #1E293B; -fx-font-weight: bold; -fx-font-size: 13px;" text="Alex Chen" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 10px; -fx-font-weight: bold;" text="CHIEF ARCHITECT" />
                            </VBox>
                            <Circle fill="#3b82f6" radius="16.0" />
                        </children>
                     </HBox>
                  </children>
               </HBox>

               <StackPane fx:id="mainContentHost" VBox.vgrow="ALWAYS" />
            </children>
         </VBox>
      </center>
   </BorderPane>
</StackPane>
