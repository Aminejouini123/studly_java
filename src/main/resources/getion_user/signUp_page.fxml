<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<!-- Using the exact same styling classes and background as the auth page -->
<StackPane prefHeight="800.0" prefWidth="1100.0" styleClass="root-pane" stylesheets="@auth.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Sign_upController">
    <children>
        <AnchorPane mouseTransparent="true" prefHeight="800.0" prefWidth="1100.0">
            <children>
                <!-- Background decorative elements matching auth page -->
                <Circle fill="#2464d1" layoutX="120.0" layoutY="120.0" opacity="0.4" radius="150.0" />
                <Circle fill="#0dcaf0" layoutX="100.0" layoutY="600.0" opacity="0.5" radius="50.0" />
                <Circle fill="#1d4899" layoutX="850.0" layoutY="200.0" opacity="0.6" radius="120.0" />

                <Rectangle arcHeight="60.0" arcWidth="60.0" fill="#377df0" height="60.0" layoutX="100.0" layoutY="350.0" opacity="0.7" rotate="45.0" width="160.0" />
                <Rectangle arcHeight="60.0" arcWidth="60.0" fill="#00c3ff" height="40.0" layoutX="160.0" layoutY="280.0" opacity="0.4" rotate="45.0" width="80.0" />
                <Rectangle arcHeight="60.0" arcWidth="60.0" fill="#295bb8" height="60.0" layoutX="-50.0" layoutY="600.0" opacity="0.8" rotate="45.0" width="160.0" />
            </children>
        </AnchorPane>
        <VBox alignment="CENTER_LEFT" maxWidth="450.0" maxHeight="-Infinity" spacing="8.0" styleClass="login-card" StackPane.alignment="CENTER">
            <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <Label styleClass="login-title" text="Sign up">
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </Label>

                        <HBox spacing="15.0">
                            <VBox HBox.hgrow="ALWAYS">
                                <Label styleClass="input-label" text="First name">
                                    <VBox.margin><Insets bottom="3.0" /></VBox.margin>
                                </Label>
                                <TextField fx:id="sign_name_id" promptText="First name" styleClass="text-input-modern" />
                                <Label fx:id="firstNameError" managed="false" styleClass="error-label" visible="false" />
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label styleClass="input-label" text="Last name">
                                    <VBox.margin><Insets bottom="3.0" /></VBox.margin>
                                </Label>
                                <TextField fx:id="sign_lname_id" promptText="Last name" styleClass="text-input-modern" />
                                <Label fx:id="lastNameError" managed="false" styleClass="error-label" visible="false" />
                            </VBox>
                        </HBox>

                        <Label styleClass="input-label" text="Email">
                            <VBox.margin><Insets top="5.0" bottom="3.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="sign_email_id" promptText="example@email.com" styleClass="text-input-modern" />
                        <Label fx:id="emailError" managed="false" styleClass="error-label" visible="false" />

                        <Label styleClass="input-label" text="Date of birth">
                            <VBox.margin><Insets top="5.0" bottom="3.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="date_id" promptText="YYYY-MM-DD" styleClass="text-input-modern" />
                        <Label fx:id="dobError" managed="false" styleClass="error-label" visible="false" />

                        <!-- Placed passwords side by side to save vertical height space -->
                        <HBox spacing="15.0">
                             <VBox.margin><Insets top="5.0" /></VBox.margin>
                             <VBox HBox.hgrow="ALWAYS">
                                 <Label styleClass="input-label" text="Password">
                                     <VBox.margin><Insets bottom="3.0" /></VBox.margin>
                                 </Label>
                                 <!-- Replaced TextField with PasswordField for security/UX -->
                                 <PasswordField fx:id="passw_s_id" promptText="Password" styleClass="text-input-modern" />
                                 <Label fx:id="passwordError" managed="false" styleClass="error-label" visible="false" />
                             </VBox>
                             <VBox HBox.hgrow="ALWAYS">
                                 <Label styleClass="input-label" text="Confirm Password">
                                     <VBox.margin><Insets bottom="3.0" /></VBox.margin>
                                 </Label>
                                 <!-- Replaced TextField with PasswordField for security/UX -->
                                 <PasswordField fx:id="pass_s_id" promptText="Confirm" styleClass="text-input-modern" />
                                 <Label fx:id="confirmPasswordError" managed="false" styleClass="error-label" visible="false" />
                             </VBox>
                        </HBox>

                        <Button fx:id="sign_button_id" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="signin-button" text="Create Account">
                            <VBox.margin>
                                <Insets bottom="10.0" top="20.0" />
                            </VBox.margin>
                        </Button>

                        <HBox alignment="CENTER">
                            <children>
                                <Hyperlink fx:id="return_login_id" styleClass="signup-link" text="Already have an account? Login here" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
</StackPane>
