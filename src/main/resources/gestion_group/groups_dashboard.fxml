<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="980.0" stylesheets="@groups_dashboard.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.group.GroupsDashboardController">
    <children>
        <VBox spacing="22.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="26.0" left="26.0" right="26.0" top="26.0"/>
            </padding>

            <children>
                <!-- Header card (Mes Groupes + Ajouter) -->
                <HBox alignment="CENTER_LEFT" styleClass="sym-header-card">
                    <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                    </padding>
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="sym-header-title" text="Mes Groupes"/>
                                <Label styleClass="sym-header-subtitle"
                                       text="Gerez et suivez tous vos groupes d'etude en un seul endroit"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false" onAction="#showAddGroupForm" styleClass="planning-primary-button"
                                text="+ Ajouter un Groupe"/>
                    </children>
                </HBox>

                <!-- Stats panel -->
                <HBox spacing="14.0" styleClass="planning-stats-panel">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="planning-stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="groupsTotalLabel" styleClass="planning-stat-value" text="0"/>
                                <Label styleClass="planning-stat-label" text="GROUPES TOTAL"/>
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="planning-stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="assignedLabel" styleClass="planning-stat-value" text="0"/>
                                <Label styleClass="planning-stat-label" text="ASSIGNES"/>
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="planning-stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="freeLabel" styleClass="planning-stat-value" text="0"/>
                                <Label styleClass="planning-stat-label" text="LIBRES"/>
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="planning-stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="totalCapacityLabel" styleClass="planning-stat-value" text="0"/>
                                <Label styleClass="planning-stat-label" text="CAPACITE TOTALE"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Content host (Liste / Details / Form) -->
                <StackPane fx:id="groupContentHost" minHeight="420.0" styleClass="planning-content-card" VBox.vgrow="ALWAYS"/>
            </children>
        </VBox>
    </children>
</AnchorPane>

