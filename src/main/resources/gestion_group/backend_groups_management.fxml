<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox prefHeight="534.0" prefWidth="1081.0" spacing="18.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.group.BackendGroupsManagementController">
    <children>
        <!-- Breadcrumb -->
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="#94A3B8" scaleX="0.85" scaleY="0.85" />
                <Label styleClass="gm-breadcrumb" text="Admin /" />
                <Label styleClass="gm-breadcrumb-strong" text="Groups Management" />
            </children>
        </HBox>

        <Label styleClass="title-text" text="Groups Management" />

        <!-- Card -->
        <VBox spacing="14.0" styleClass="gm-card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label styleClass="gm-card-title" text="All Groups" />
                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="gm-search">
                                    <children>
                                        <SVGPath content="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5C16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79L19 20.49 20.49 19l-4.99-5zM9.5 14C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#64748B" scaleX="0.9" scaleY="0.9" />
                                        <TextField fx:id="searchField" promptText="Search categories..." styleClass="gm-search-input" />
                                    </children>
                                </HBox>

                                <Button fx:id="sortCreatedAtBtn" mnemonicParsing="false" onAction="#toggleSortCreatedAt" styleClass="gm-icon-btn">
                                    <graphic>
                                        <SVGPath content="M3 18h6v-2H3v2zm0-5h12v-2H3v2zm0-7v2h18V6H3z" fill="#64748B" scaleX="0.9" scaleY="0.9" />
                                    </graphic>
                                </Button>

                                <Button fx:id="exportCsvBtn" mnemonicParsing="false" onAction="#exportCsv" styleClass="gm-icon-btn">
                                    <graphic>
                                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V7h2v2zm6 8h-4v-2h4v2zm0-4h-4v-2h4v2zm0-4h-4V7h4v2z" fill="#64748B" scaleX="0.85" scaleY="0.85" />
                                    </graphic>
                                </Button>

                                <Button fx:id="exportPdfBtn" mnemonicParsing="false" onAction="#exportPdf" styleClass="gm-icon-btn">
                                    <graphic>
                                        <SVGPath content="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm1 7V3.5L18.5 9H15z" fill="#64748B" scaleX="0.9" scaleY="0.9" />
                                    </graphic>
                                </Button>

                                <Button fx:id="addGroupBtn" mnemonicParsing="false" onAction="#addGroup" styleClass="gm-add-btn" text="+  Add Group" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <StackPane VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="groupsTable" styleClass="gm-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
                                <TableColumn fx:id="colCategory" minWidth="220.0" prefWidth="-1.0" text="CATEGORY" />
                                <TableColumn fx:id="colCapacity" minWidth="140.0" prefWidth="-1.0" text="CAPACITY" />
                                <TableColumn fx:id="colCreatedBy" minWidth="220.0" prefWidth="-1.0" text="CREATED BY" />
                                <TableColumn fx:id="colCreatedAt" minWidth="180.0" prefWidth="-1.0" text="CREATED AT" />
                                <TableColumn fx:id="colStatus" minWidth="140.0" prefWidth="-1.0" text="STATUS" />
                                <TableColumn fx:id="colActions" prefWidth="130.0" resizable="false" sortable="false" text="ACTIONS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <!-- Empty state overlay -->
                        <VBox fx:id="emptyState" alignment="CENTER" managed="false" spacing="10.0" styleClass="gm-empty" visible="false">
                            <children>
                                <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z" fill="#94A3B8" scaleX="1.2" scaleY="1.2" />
                                <Label styleClass="gm-empty-title" text="No groups found." />
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </VBox>
    </children>
</VBox>
