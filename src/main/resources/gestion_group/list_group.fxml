<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="620.0" prefWidth="940.0" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.group.ListGroupController">
    <children>
        <VBox spacing="14.0" AnchorPane.bottomAnchor="18.0" AnchorPane.leftAnchor="18.0" AnchorPane.rightAnchor="18.0"
              AnchorPane.topAnchor="18.0">

            <HBox alignment="CENTER_LEFT">
                <children>
                    <Label styleClass="section-header" text="Liste des Groupes"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" prefWidth="520.0" promptText="Rechercher par categorie..." styleClass="search-field"/>
                    <Button fx:id="searchButton" mnemonicParsing="false" onAction="#applySearch" styleClass="search-button" text=""/>
                </children>
            </HBox>

            <Label fx:id="statusLabel" styleClass="muted" text=""/>

            <StackPane VBox.vgrow="ALWAYS">
                <children>
                    <ListView fx:id="groupsList" VBox.vgrow="ALWAYS"/>

                    <!-- Empty state overlay -->
                    <VBox fx:id="emptyStateBox" alignment="CENTER" spacing="10.0" visible="false" managed="false"
                          styleClass="textarea-like">
                        <padding>
                            <Insets bottom="28.0" left="28.0" right="28.0" top="28.0"/>
                        </padding>
                        <children>
                            <Label styleClass="empty-title" text="Aucun groupe trouve"/>
                            <Label styleClass="empty-desc"
                                   text="Vous n'avez pas encore cree de groupe. Creez votre premier groupe d'etude des maintenant!"
                                   wrapText="true"/>
                            <Button mnemonicParsing="false" onAction="#openAddGroup" styleClass="btn-primary"
                                    text="Creer mon premier groupe"/>
                        </children>
                    </VBox>
                </children>
            </StackPane>
        </VBox>
    </children>
</AnchorPane>

