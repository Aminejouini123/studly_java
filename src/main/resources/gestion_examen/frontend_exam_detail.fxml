<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.web.WebView?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1200.0" style="-fx-background-color: #f8f9fa;" stylesheets="@../TEMPLATE/frontend_style.css,@../TEMPLATE/studly_ai_chat.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.exams.ExamDetailController">
    <children>
        <BorderPane styleClass="course-detail-container">
            <top>
                <VBox spacing="25.0">
                    <padding>
                        <Insets left="60.0" right="60.0" top="30.0" />
                    </padding>
                    <children>
                        <!-- Top Navigation Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: white; -fx-background-radius: 50; -fx-padding: 10 24; -fx-text-fill: #64748B; -fx-font-weight: 800; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" text="←  Back to List" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="15.0">
                                   <children>
                                      <Label style="-fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 12px;" text="TERM STATUS" />
                                      <Label fx:id="detailCreatedAt" style="-fx-text-fill: #475569; -fx-font-weight: 800; -fx-font-size: 12px; -fx-background-color: #F1F5F9; -fx-padding: 5 12; -fx-background-radius: 8;" text="Just now" />
                                   </children>
                                </HBox>
                            </children>
                        </HBox>

                        <!-- Exam Hero Header (Professional Blue Gradient) -->
                        <HBox fx:id="heroHeader" alignment="CENTER_LEFT" spacing="40.0" styleClass="hero-header-detail" style="-fx-background-color: linear-gradient(to bottom right, #0059A9, #004481);">
                            <children>
                                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <FlowPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Label fx:id="examType" styleClass="badge-pill-detail" text="CRITICAL EVALUATION" />
                                                <Label fx:id="examStatus" styleClass="badge-pill-detail" text="PENDING" />
                                                <Label fx:id="examDifficulty" styleClass="badge-pill-detail" text="MEDIUM" />
                                            </children>
                                        </FlowPane>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label fx:id="courseNameLabel" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-weight: 900; -fx-font-size: 14px;" text="COURSE NAME" />
                                                <Label fx:id="examTitle" styleClass="hero-title-detail" text="Advanced Examination" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <HBox spacing="40.0">
                                            <children>
                                                <HBox alignment="CENTER" spacing="12.0">
                                                   <children>
                                                      <SVGPath content="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z" fill="WHITE" opacity="0.8" scaleX="1.1" scaleY="1.1" />
                                                      <VBox>
                                                         <children>
                                                            <Label style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px; -fx-font-weight: 800;" text="DURATION" />
                                                            <Label fx:id="examDuration" styleClass="hero-info-pill" style="-fx-font-weight: 800;" text="120 min" />
                                                         </children>
                                                      </VBox>
                                                   </children>
                                                </HBox>
                                                <HBox alignment="CENTER" spacing="12.0">
                                                   <children>
                                                      <SVGPath content="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z" fill="WHITE" opacity="0.8" scaleX="1.1" scaleY="1.1" />
                                                      <VBox>
                                                         <children>
                                                            <Label style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px; -fx-font-weight: 800;" text="EXAM DATE" />
                                                            <Label fx:id="examDate" styleClass="hero-info-pill" style="-fx-font-weight: 800;" text="2026-04-14" />
                                                         </children>
                                                      </VBox>
                                                   </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <!-- Score Module -->
                                <VBox alignment="CENTER" spacing="10.0">
                                   <children>
                                       <StackPane fx:id="statRingContainer" prefHeight="140.0" prefWidth="140.0">
                                           <children>
                                               <Group>
                                                   <children>
                                                       <Circle radius="60.0" style="-fx-fill: rgba(255,255,255,0.1); -fx-stroke: rgba(255,255,255,0.1); -fx-stroke-width: 8;" />
                                                       <Arc fx:id="scoreArc" length="270.0" radiusX="60.0" radiusY="60.0" startAngle="90.0" style="-fx-fill: transparent; -fx-stroke: white; -fx-stroke-width: 8; -fx-stroke-line-cap: round;" type="OPEN" />
                                                   </children>
                                               </Group>
                                               <VBox alignment="CENTER">
                                                   <children>
                                                       <Label fx:id="examGrade" styleClass="stat-value-detail" text="18.5" />
                                                       <Label styleClass="stat-label-detail" text="SCORE" />
                                                   </children>
                                               </VBox>
                                           </children>
                                       </StackPane>
                                   </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" styleClass="scroll-pane" BorderPane.alignment="CENTER">
                    <content>
                        <HBox alignment="TOP_CENTER" spacing="30.0">
                            <padding>
                                <Insets bottom="60.0" left="60.0" right="60.0" top="40.0" />
                            </padding>
                            <children>
                                <!-- Left Column: Examination Materials -->
                                <VBox spacing="30.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <!-- Resource Links -->
                                        <VBox spacing="20.0" styleClass="glass-card" style="-fx-padding: 30;">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                    <children>
                                                        <SVGPath content="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" fill="#0059A9" />
                                                        <Label styleClass="section-title" text="Evaluation Materials &amp; Resources" />
                                                    </children>
                                                </HBox>
                                                
                                                <VBox spacing="15.0">
                                                    <children>
                                                        <!-- External Link Tile -->
                                                        <HBox fx:id="resourceLinkBox" alignment="CENTER_LEFT" spacing="20.0" styleClass="resource-tile-detail">
                                                            <children>
                                                                <StackPane style="-fx-background-color: #EEF2FF; -fx-background-radius: 12; -fx-padding: 15;">
                                                                   <children>
                                                                      <SVGPath content="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" fill="#4F46E5" scaleX="1.2" scaleY="1.2" />
                                                                   </children>
                                                                </StackPane>
                                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label style="-fx-font-weight: 900; -fx-text-fill: #0F172A; -fx-font-size: 14px;" text="External Evidence" />
                                                                        <Label fx:id="linkLabel" style="-fx-text-fill: #4F46E5; -fx-font-weight: bold;" text="https://exam-portal.edu" />
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>

                                                        <!-- File Preview -->
                                                        <!-- File Preview Component - Premium Redesign -->
                                                        <VBox fx:id="filePreviewBox" spacing="0.0" style="-fx-border-color: #CBD5E1; -fx-border-radius: 16; -fx-background-radius: 16; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,51,102,0.12), 20, 0, 0, 6);">
                                                            <children>
                                                                <!-- Premium PDF Viewer Toolbar -->
                                                                <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-background-color: linear-gradient(to right, #1E293B, #334155); -fx-background-radius: 16 16 0 0; -fx-padding: 14 20;">
                                                                    <children>
                                                                        <StackPane fx:id="fileTypeBadge" alignment="CENTER" minWidth="48.0" prefWidth="48.0" prefHeight="48.0" style="-fx-background-color: #EF4444; -fx-background-radius: 12;">
                                                                           <children>
                                                                              <Label fx:id="fileTypeBadgeLabel" style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 11px;" text="PDF" />
                                                                           </children>
                                                                        </StackPane>
                                                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                                           <children>
                                                                              <Label style="-fx-font-size: 9px; -fx-font-weight: 900; -fx-text-fill: #94A3B8; -fx-letter-spacing: 0.12em;" text="EXAMINATION MATERIAL" />
                                                                              <Label fx:id="fileNameLabel" style="-fx-font-weight: 700; -fx-text-fill: #F8FAFC; -fx-font-size: 14px;" text="exam_paper.pdf" wrapText="true" maxWidth="1.7976931348623157E308" />
                                                                              <Label fx:id="detailFileMeta" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px; -fx-font-weight: 600;" text="PDF · —" />
                                                                           </children>
                                                                        </VBox>
                                                                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                                                           <children>
                                                                              <Button fx:id="openFileToolbarBtn" mnemonicParsing="false" onAction="#handleOpenExternally" minWidth="104.0" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: 700; -fx-font-size: 12px; -fx-padding: 8 16; -fx-cursor: hand;" text="Open file" />
                                                                              <Button fx:id="downloadFileToolbarBtn" mnemonicParsing="false" onAction="#handleDownloadFile" minWidth="96.0" style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: #E2E8F0; -fx-background-radius: 10; -fx-font-weight: 700; -fx-font-size: 12px; -fx-padding: 8 14; -fx-cursor: hand;" text="Download" />
                                                                              <Button fx:id="togglePreviewBtn" mnemonicParsing="false" onAction="#handleTogglePreview" minWidth="124.0" style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: #E2E8F0; -fx-background-radius: 10; -fx-font-weight: 700; -fx-font-size: 12px; -fx-padding: 8 14; -fx-cursor: hand;" text="Hide preview" />
                                                                           </children>
                                                                        </HBox>
                                                                    </children>
                                                                </HBox>
                                                                
                                                                <!-- Advanced PDF Viewer Navigation & Zoom -->
                                                                <HBox fx:id="pdfControlsBox" alignment="CENTER" spacing="15.0" style="-fx-background-color: #1E293B; -fx-padding: 8 20; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                                                                   <children>
                                                                      <HBox spacing="5.0" alignment="CENTER">
                                                                         <children>
                                                                            <Button fx:id="pdfPrevBtn" mnemonicParsing="false" onAction="#handlePdfPrevPage" styleClass="pdf-nav-btn" text="◀" />
                                                                            <Label fx:id="pdfPageIndicator" style="-fx-text-fill: #F8FAFC; -fx-font-weight: 800; -fx-font-size: 13px;" text="Page 1 of 1" />
                                                                            <Button fx:id="pdfNextBtn" mnemonicParsing="false" onAction="#handlePdfNextPage" styleClass="pdf-nav-btn" text="▶" />
                                                                         </children>
                                                                      </HBox>
                                                                      <Separator orientation="VERTICAL" style="-fx-opacity: 0.2;" />
                                                                      <HBox spacing="8.0" alignment="CENTER">
                                                                         <children>
                                                                            <Button fx:id="pdfZoomOutBtn" mnemonicParsing="false" onAction="#handlePdfZoomOut" styleClass="pdf-nav-btn" text="−" />
                                                                            <Label fx:id="pdfZoomLabel" style="-fx-text-fill: #F8FAFC; -fx-font-weight: 800; -fx-font-size: 13px; -fx-min-width: 50;" text="100%" alignment="CENTER" />
                                                                            <Button fx:id="pdfZoomInBtn" mnemonicParsing="false" onAction="#handlePdfZoomIn" styleClass="pdf-nav-btn" text="+" />
                                                                         </children>
                                                                      </HBox>
                                                                      <Separator orientation="VERTICAL" style="-fx-opacity: 0.2;" />
                                                                      <HBox spacing="8.0" alignment="CENTER">
                                                                         <children>
                                                                            <Button fx:id="pdfFitWidthBtn" mnemonicParsing="false" onAction="#handlePdfFitWidth" styleClass="pdf-nav-btn" text="↔" />
                                                                            <Button fx:id="pdfFitPageBtn" mnemonicParsing="false" onAction="#handlePdfFitPage" styleClass="pdf-nav-btn" text="⛶" />
                                                                            <Button fx:id="pdfFullscreenBtn" mnemonicParsing="false" onAction="#handlePdfFullscreen" styleClass="pdf-nav-btn" text="⛶" />
                                                                         </children>
                                                                      </HBox>
                                                                      <Separator orientation="VERTICAL" style="-fx-opacity: 0.2;" />
                                                                      <Button fx:id="ttsBtn" mnemonicParsing="false" onAction="#handleReadAloud" styleClass="pdf-nav-btn" text="🔊" />
                                                                   </children>
                                                                </HBox>

                                                                <VBox fx:id="previewContentArea" minHeight="320.0" prefHeight="520.0" style="-fx-background-color: #0F172A; -fx-background-radius: 0 0 16 16;">
                                                                   <children>
                                                                      <StackPane minHeight="320.0" prefHeight="520.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #0F172A;">
                                                                         <children>
                                                                            <WebView fx:id="pdfWebView" prefHeight="520.0" prefWidth="-1.0" />
                                                                            <ScrollPane fx:id="pdfFxScroll" fitToWidth="false" fitToHeight="false" visible="false" managed="false" prefHeight="520.0" pannable="true" style="-fx-background: #0F172A; -fx-background-color: #0F172A;">
                                                                               <content>
                                                                                  <StackPane fx:id="pdfCenterPane" alignment="CENTER" style="-fx-padding: 22; -fx-background-color: #0F172A;">
                                                                                     <children>
                                                                                        <javafx.scene.image.ImageView fx:id="pdfPageImageView" preserveRatio="true" smooth="true" cache="true" />
                                                                                     </children>
                                                                                  </StackPane>
                                                                               </content>
                                                                            </ScrollPane>
                                                                            <VBox fx:id="filePlaceholder" alignment="CENTER" spacing="20.0" visible="false" style="-fx-background-color: #1E293B; -fx-background-radius: 0 0 16 16;">
                                                                               <children>
                                                                                  <StackPane style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 50; -fx-padding: 25;">
                                                                                     <children>
                                                                                        <SVGPath content="M13 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V9l-7-7zm0 1.5L18.5 9H13V3.5z" fill="#475569" scaleX="2.5" scaleY="2.5" />
                                                                                     </children>
                                                                                  </StackPane>
                                                                                  <VBox alignment="CENTER" spacing="8.0">
                                                                                     <children>
                                                                                        <Label style="-fx-text-fill: #94A3B8; -fx-font-weight: 700; -fx-font-size: 16px;" text="No Preview Available" />
                                                                                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 13px;" text="Attach a PDF to see it here, or click 'Open' to use an external viewer." wrapText="true" maxWidth="280" />
                                                                                     </children>
                                                                                  </VBox>
                                                                               </children>
                                                                               <padding><Insets top="60.0" bottom="60.0" /></padding>
                                                                            </VBox>
                                                                         </children>
                                                                      </StackPane>
                                                                   </children>
                                                                </VBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- Right Column: Sidebar (Management) -->
                                <VBox maxWidth="380.0" minWidth="320.0" spacing="30.0">
                                    <children>
                                        <!-- Actions Card -->
                                        <VBox spacing="20.0" styleClass="glass-card" style="-fx-padding: 25;">
                                            <children>
                                                <Label styleClass="sidebar-heading" text="EXAM MANAGEMENT" />
                                                <VBox spacing="12.0">
                                                    <children>
                                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEditAction" styleClass="sidebar-action-btn" text="✎   Modify Entry" />
                                                        <Separator style="-fx-opacity: 0.5;">
                                                           <padding>
                                                              <Insets bottom="5.0" top="5.0" />
                                                           </padding>
                                                        </Separator>
                                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDelete" styleClass="sidebar-action-btn, sidebar-action-btn-delete" text="🗑   Remove Exam" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <!-- Metadata Overview -->
                                        <VBox spacing="20.0" styleClass="glass-card" style="-fx-padding: 25;">
                                            <children>
                                                <Label styleClass="sidebar-heading" text="EXAM METADATA" />
                                                <VBox spacing="18.0">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label styleClass="meta-label-detail" text="Target Score" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label fx:id="targetGradeLabel" styleClass="meta-value-detail" style="-fx-background-color: #F5F3FF; -fx-text-fill: #7C3AED;" text="20.0" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>

        <!-- Floating Studly AI Chat (button + drawer panel) -->
        <StackPane fx:id="chatOverlay" alignment="BOTTOM_RIGHT" pickOnBounds="false">
            <padding>
                <Insets bottom="26.0" right="26.0" />
            </padding>
            <children>
                <VBox fx:id="chatPanel" managed="false" prefHeight="520.0" prefWidth="380.0" spacing="0.0" styleClass="studly-ai-panel" visible="false" StackPane.alignment="BOTTOM_RIGHT">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="studly-ai-header">
                            <children>
                                <StackPane style="-fx-background-color: rgba(99,102,241,0.18); -fx-background-radius: 999; -fx-padding: 6;">
                                    <children>
                                        <SVGPath content="M12 2a4 4 0 0 0-4 4v1H6a3 3 0 0 0-3 3v5a3 3 0 0 0 3 3h1v2a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2h1a3 3 0 0 0 3-3v-5a3 3 0 0 0-3-3h-2V6a4 4 0 0 0-4-4zm-2 5V6a2 2 0 1 1 4 0v1h-4zm-2 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm8 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" fill="#A5B4FC" scaleX="0.9" scaleY="0.9" />
                                    </children>
                                </StackPane>
                                <VBox spacing="1.0">
                                    <children>
                                        <Label styleClass="studly-ai-title" text="Exam AI Tutor" />
                                        <Label styleClass="studly-ai-subtitle" text="Solve and explain questions" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="chatStatusLabel" style="-fx-text-fill: #94A3B8; -fx-font-weight: 800; -fx-font-size: 11px;" text="" />
                                <Button mnemonicParsing="false" onAction="#handleExplainExam" styleClass="studly-ai-header-btn" text="Expliquer" />
                                <Button mnemonicParsing="false" onAction="#minimizeChat" styleClass="studly-ai-header-btn" text="—" />
                                <Button mnemonicParsing="false" onAction="#closeChat" styleClass="studly-ai-header-btn,studly-ai-close-btn" text="✕" />
                            </children>
                        </HBox>

                        <ListView fx:id="chatListView" styleClass="studly-ai-list" VBox.vgrow="ALWAYS" />

                        <HBox spacing="10.0" styleClass="studly-ai-input-bar">
                            <children>
                                <TextField fx:id="chatInputField" onAction="#handleSendChat" promptText="Ask about a question..." styleClass="studly-ai-input" HBox.hgrow="ALWAYS" />
                                <Button fx:id="chatSendButton" mnemonicParsing="false" onAction="#handleSendChat" styleClass="studly-ai-send" text="Send" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Button fx:id="chatFabButton" mnemonicParsing="false" onAction="#toggleChatPanel" styleClass="studly-ai-fab" StackPane.alignment="BOTTOM_RIGHT">
                    <graphic>
                        <SVGPath content="M12 2a4 4 0 0 0-4 4v1H6a3 3 0 0 0-3 3v5a3 3 0 0 0 3 3h1v2a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2h1a3 3 0 0 0 3-3v-5a3 3 0 0 0-3-3h-2V6a4 4 0 0 0-4-4zm-2 5V6a2 2 0 1 1 4 0v1h-4zm-2 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm8 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" fill="WHITE" scaleX="1.05" scaleY="1.05" />
                    </graphic>
                </Button>
            </children>
        </StackPane>

        <!-- Premium Delete Modal Overlay -->
        <StackPane fx:id="deleteModalOverlay" styleClass="modal-overlay" visible="false">
            <children>
                <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="450.0" spacing="25.0" styleClass="modal-content-detail">
                    <children>
                        <Circle fill="#FEE2E2" radius="35.0" stroke="WHITE" strokeWidth="0.0" />
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="Confirm Deletion" />
                                <Label alignment="CENTER" lineSpacing="5.0" text="Are you sure you want to delete this exam record? All associated grades and materials will be removed. This action is irreversible." textAlignment="CENTER" wrapText="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#closeDeleteModal" prefWidth="150.0" styleClass="btn-modal-cancel" text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#confirmDelete" prefWidth="150.0" styleClass="btn-modal-delete" text="Delete Exam" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
