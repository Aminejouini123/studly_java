<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="620.0" prefWidth="940.0" stylesheets="@events_list.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.gestiondetemps.EventListController">
   <children>
      <VBox spacing="18.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label styleClass="events-title" text="Liste des événements" />
            <HBox alignment="CENTER_LEFT" spacing="14.0">
               <children>
                  <Label styleClass="events-subtitle" text="Vos événements" />
                  <Label styleClass="filter-badge filter-badge-date" text="Date" />
                  <Label styleClass="filter-badge filter-badge-priority" text="Priority" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="14.0">
               <children>
                  <TextField fx:id="searchField" prefWidth="280.0" promptText="Rechercher par titre, type, lieu..." styleClass="events-search-field" />
                  <ComboBox fx:id="sortComboBox" prefWidth="240.0" styleClass="events-sort-box" />
               </children>
            </HBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="events-scroll" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="16.0">
                     <padding>
                        <Insets bottom="10.0" top="4.0" />
                     </padding>
                     <children>
                        <Label fx:id="emptyStateLabel" managed="false" styleClass="empty-state" text="Aucun événement trouvé." visible="false" />
                        <FlowPane fx:id="cardsContainer" hgap="18.0" prefWrapLength="900.0" vgap="18.0" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
