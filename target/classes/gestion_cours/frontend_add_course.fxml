<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" prefHeight="900.0" prefWidth="1200.0" style="-fx-background-color: #f8f9fa;" stylesheets="@../TEMPLATE/frontend_style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.courses.CourseAddController">
   <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
      <content>
         <VBox alignment="TOP_CENTER" spacing="0.0" style="-fx-background-color: transparent; -fx-padding: 20 0 60 0;">
            <children>
               <!-- Header Container -->
               <VBox maxWidth="1000.0" style="-fx-background-color: #004fb0; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0, 51, 102, 0.15), 30, 0, 0, 10);">
                  <padding>
                     <Insets bottom="100.0" left="40.0" right="40.0" top="30.0" />
                  </padding>
                  <children>
                     <Button mnemonicParsing="false" onMouseClicked="#goToCourses" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50; -fx-padding: 8 20; -fx-cursor: hand;" text="← Back to Courses" />
                     <VBox alignment="CENTER" spacing="10.0">
                        <VBox.margin>
                           <Insets top="20.0" />
                        </VBox.margin>
                        <children>
                           <Label fx:id="formTitle" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: white;" text="Add a New Course" />
                           <Label style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.9);" text="Fill in the course information to add it to your list" />
                        </children>
                     </VBox>
                  </children>
               </VBox>

               <!-- Form Card -->
               <VBox maxWidth="960.0" spacing="40.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: linear-gradient(to right, #00c6ff, #0072ff) transparent transparent transparent; -fx-border-width: 4 0 0 0; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 30, 0, 0, 10); -fx-translate-y: -60;">
                  <padding>
                     <Insets bottom="50.0" left="50.0" right="50.0" top="40.0" />
                  </padding>
                  <children>

                     <!-- 1. General Information Section -->
                     <VBox spacing="20.0" style="-fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 25 0;">
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="10.0">
                              <children>
                                 <Region prefHeight="18.0" prefWidth="4.0" style="-fx-background-color: #00c6ff; -fx-background-radius: 2;" />
                                 <Label style="-fx-background-color: #00c6ff; -fx-text-fill: white; -fx-background-radius: 50; -fx-font-weight: bold; -fx-font-size: 14px; -fx-min-width: 24; -fx-min-height: 24; -fx-max-width: 24; -fx-max-height: 24; -fx-alignment: center;" text="i" />
                                 <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #003366;" text="General Information" />
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Course Name" />
                                        <TextField fx:id="courseNameField" promptText="Ex: Introduction to Algorithms" styleClass="modern-input" />
                                        <Label fx:id="errName" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Teacher Email" />
                                        <TextField fx:id="teacherEmailField" promptText="professor@univ.edu" styleClass="modern-input" />
                                        <Label fx:id="errEmail" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>

                     <!-- 2. Course Settings Section -->
                     <VBox spacing="20.0" style="-fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 25 0;">
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="10.0">
                              <children>
                                 <Region prefHeight="18.0" prefWidth="4.0" style="-fx-background-color: #00c6ff; -fx-background-radius: 2;" />
                                 <Label style="-fx-background-color: #00c6ff; -fx-text-fill: white; -fx-background-radius: 50; -fx-font-weight: bold; -fx-font-size: 14px; -fx-min-width: 24; -fx-min-height: 24; -fx-max-width: 24; -fx-max-height: 24; -fx-alignment: center;" text="⚙" />
                                 <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #003366;" text="Course Settings" />
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Semester" />
                                        <ComboBox fx:id="semesterComboBox" maxWidth="Infinity" promptText="Select" styleClass="modern-combo">
                                           <items>
                                              <FXCollections fx:factory="observableArrayList">
                                                 <String fx:value="Semester 1" />
                                                 <String fx:value="Semester 2" />
                                                 <String fx:value="Summer" />
                                              </FXCollections>
                                           </items>
                                        </ComboBox>
                                        <Label fx:id="errSemester" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Difficulty Level" />
                                        <ComboBox fx:id="difficultyComboBox" maxWidth="Infinity" promptText="Select" styleClass="modern-combo">
                                           <items>
                                              <FXCollections fx:factory="observableArrayList">
                                                 <String fx:value="Easy" />
                                                 <String fx:value="Medium" />
                                                 <String fx:value="Hard" />
                                              </FXCollections>
                                           </items>
                                        </ComboBox>
                                        <Label fx:id="errDifficulty" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Course Type" />
                                        <ComboBox fx:id="typeComboBox" maxWidth="Infinity" promptText="Select" styleClass="modern-combo">
                                           <items>
                                              <FXCollections fx:factory="observableArrayList">
                                                 <String fx:value="Online" />
                                                 <String fx:value="In-Person" />
                                                 <String fx:value="Mixed" />
                                              </FXCollections>
                                           </items>
                                        </ComboBox>
                                        <Label fx:id="errType" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Priority" />
                                        <ComboBox fx:id="priorityComboBox" maxWidth="Infinity" promptText="Select" styleClass="modern-combo">
                                           <items>
                                              <FXCollections fx:factory="observableArrayList">
                                                 <String fx:value="Low" />
                                                 <String fx:value="Medium" />
                                                 <String fx:value="High" />
                                              </FXCollections>
                                           </items>
                                        </ComboBox>
                                        <Label fx:id="errPriority" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Status" />
                                        <ComboBox fx:id="statusComboBox" maxWidth="Infinity" promptText="Select" styleClass="modern-combo">
                                           <items>
                                              <FXCollections fx:factory="observableArrayList">
                                                 <String fx:value="Pending" />
                                                 <String fx:value="Active" />
                                                 <String fx:value="Completed" />
                                              </FXCollections>
                                           </items>
                                        </ComboBox>
                                        <Label fx:id="errStatus" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Coefficient (0–10)" />
                                        <TextField fx:id="coefficientField" promptText="e.g. 3.5" styleClass="modern-input" />
                                        <Label fx:id="errCoeff" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>

                     <!-- 3. Planning & Resources Section -->
                     <VBox spacing="20.0">
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="10.0">
                              <children>
                                 <Region prefHeight="18.0" prefWidth="4.0" style="-fx-background-color: #00c6ff; -fx-background-radius: 2;" />
                                 <Label style="-fx-background-color: #00c6ff; -fx-text-fill: white; -fx-background-radius: 50; -fx-font-weight: bold; -fx-font-size: 12px; -fx-min-width: 24; -fx-min-height: 24; -fx-max-width: 24; -fx-max-height: 24; -fx-alignment: center;" text="📅" />
                                 <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #003366;" text="Planning &amp; Resources" />
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Duration (hours)" />
                                        <TextField fx:id="durationField" promptText="Ex: 30" styleClass="modern-input" />
                                        <Label fx:id="errDuration" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                                 <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Course File" />
                                       <HBox spacing="10.0">
                                          <children>
                                             <TextField fx:id="courseFileField" promptText="path/to/file.pdf" styleClass="modern-input" HBox.hgrow="ALWAYS" />
                                             <Button mnemonicParsing="false" onAction="#handleBrowseFile" style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 15; -fx-cursor: hand;" text="Browse..." />
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                 <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Course Link (Video)" />
                                       <TextField fx:id="courseLinkField" promptText="https://meet.google.com/..." styleClass="modern-input" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>

                           <HBox spacing="30.0">
                              <children>
                                 <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Comments" />
                                       <TextArea fx:id="commentArea" prefRowCount="4" promptText="Additional notes or instructions..." styleClass="modern-area" wrapText="true" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>

                     <!-- Actions -->
                     <VBox>
                        <children>
                           <Region prefHeight="1.0" style="-fx-background-color: #f0f0f0;" />
                           <HBox alignment="CENTER_RIGHT" spacing="15.0">
                              <VBox.margin>
                                 <Insets top="20.0" />
                              </VBox.margin>
                              <children>
                                 <Button fx:id="submitBtn" mnemonicParsing="false" onAction="#addCourse" style="-fx-background-color: linear-gradient(to right, #003366, #004080); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 35; -fx-cursor: hand; -fx-font-size: 16px; -fx-effect: dropshadow(gaussian, rgba(0, 51, 102, 0.2), 10, 0, 0, 4);" text="💾 Add Course" />
                              </children>
                           </HBox>
                        </children>
                     </VBox>

                  </children>
               </VBox>
            </children>
         </VBox>
      </content>
   </ScrollPane>
</StackPane>
