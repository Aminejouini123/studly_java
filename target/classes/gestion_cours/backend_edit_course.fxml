<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" stylesheets="@../TEMPLATE/backend_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.courses.CourseEditController">
    <children>
        <VBox styleClass="admin-form-container" maxWidth="900.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="formTitle" styleClass="admin-form-section-title" text="Edit Administrative Record" />
                                <Label styleClass="subtitle-text" text="Update the persistent data for this course entry." />
                            </children>
                        </VBox>
                        <Button onMouseClicked="#handleBack" styleClass="btn-secondary" text="Cancel Changes" />
                    </children>
                </HBox>

                <Region prefHeight="10.0" />

                <!-- 1. Identification -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="COURSE IDENTIFICATION" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Internal Name" styleClass="admin-form-label" />
                                        <TextField fx:id="courseNameField" styleClass="admin-form-input" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Teacher Email" styleClass="admin-form-label" />
                                        <TextField fx:id="teacherEmailField" styleClass="admin-form-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 2. Academic Parameters -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="ACADEMIC PARAMETERS" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Semester" styleClass="admin-form-label" />
                                        <ComboBox fx:id="semesterComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Difficulty" styleClass="admin-form-label" />
                                        <ComboBox fx:id="difficultyComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Course Type" styleClass="admin-form-label" />
                                        <ComboBox fx:id="typeComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Priority" styleClass="admin-form-label" />
                                        <ComboBox fx:id="priorityComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Status" styleClass="admin-form-label" />
                                        <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="admin-form-combo" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Coefficient" styleClass="admin-form-label" />
                                        <TextField fx:id="coefficientField" styleClass="admin-form-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 3. Logistics -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="LOGISTICS &amp; RESOURCES" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" prefWidth="150.0">
                                    <children>
                                        <Label text="Duration (hrs)" styleClass="admin-form-label" />
                                        <TextField fx:id="durationField" styleClass="admin-form-input" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Resource File Path" styleClass="admin-form-label" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <TextField fx:id="courseFileField" HBox.hgrow="ALWAYS" styleClass="admin-form-input" />
                                                <Button onAction="#handleBrowseFile" styleClass="btn-secondary" text="Browse" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Internal Comments" styleClass="admin-form-label" />
                                <TextArea fx:id="commentArea" prefRowCount="3" styleClass="admin-form-input" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Actions -->
                <HBox styleClass="admin-form-button-bar">
                    <children>
                        <Button fx:id="submitBtn" onAction="#saveChanges" styleClass="btn-primary" text="💾 Apply Changes" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
