<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.courses.CourseAddController">
    <children>
         <VBox alignment="TOP_CENTER" spacing="0.0" style="-fx-background-color: transparent; -fx-padding: 0 0 40 0;">
            <children>
               <!-- Header Container -->
               <VBox style="-fx-background-color: #004fb0; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0, 51, 102, 0.15), 30, 0, 0, 10);">
                  <padding>
                     <Insets bottom="80.0" left="40.0" right="40.0" top="30.0" />
                  </padding>
                  <children>
                     <Button mnemonicParsing="false" onMouseClicked="#goToCourses" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50; -fx-padding: 8 20; -fx-cursor: hand;" text="← Back to Courses" />
                     <VBox alignment="CENTER" spacing="10.0">
                        <VBox.margin>
                           <Insets top="15.0" />
                        </VBox.margin>
                        <children>
                           <Label fx:id="formTitle" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: white;" text="Add a New Course" />
                           <Label style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9);" text="Fill in the course information to add it to your list" />
                        </children>
                     </VBox>
                  </children>
               </VBox>

               <!-- Form Card -->
               <VBox spacing="35.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #00c6ff transparent transparent transparent; -fx-border-width: 4 0 0 0; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 30, 0, 0, 10); -fx-translate-y: -50;">
                  <VBox.margin>
                      <Insets left="20.0" right="20.0" />
                  </VBox.margin>
                  <padding>
                     <Insets bottom="40.0" left="40.0" right="40.0" top="35.0" />
                  </padding>
                  <children>

                     <!-- 1. General Information Section -->
                     <VBox spacing="15.0" style="-fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="10.0">
                              <children>
                                 <Region prefHeight="18.0" prefWidth="4.0" style="-fx-background-color: #00c6ff; -fx-background-radius: 2;" />
                                 <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #003366;" text="General Information" />
                              </children>
                           </HBox>

                           <HBox spacing="25.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Course Name" />
                                        <TextField fx:id="courseNameField" promptText="Ex: Introduction to Algorithms" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;" />
                                        <Label fx:id="errName" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Teacher Email" />
                                        <TextField fx:id="teacherEmailField" promptText="professor@univ.edu" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;" />
                                        <Label fx:id="errEmail" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" managed="false" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>

                     <!-- 2. Course Settings Section -->
                     <VBox spacing="15.0" style="-fx-border-color: transparent transparent #e9ecef transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 20 0;">
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="10.0">
                              <children>
                                 <Region prefHeight="18.0" prefWidth="4.0" style="-fx-background-color: #00c6ff; -fx-background-radius: 2;" />
                                 <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #003366;" text="Course Settings" />
                              </children>
                           </HBox>

                           <HBox spacing="25.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Semester" />
                                        <ComboBox fx:id="semesterComboBox" maxWidth="Infinity" promptText="Select" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Difficulty Level" />
                                        <ComboBox fx:id="difficultyComboBox" maxWidth="Infinity" promptText="Select" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>

                           <HBox spacing="25.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Status" />
                                        <ComboBox fx:id="statusComboBox" maxWidth="Infinity" promptText="Select" />
                                     </children>
                                  </VBox>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Coefficient (0–10)" />
                                        <TextField fx:id="coefficientField" promptText="e.g. 3.5" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;" />
                                     </children>
                                  </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>

                     <!-- 3. Planning & Resources Section -->
                     <VBox spacing="15.0">
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="10.0">
                              <children>
                                 <Region prefHeight="18.0" prefWidth="4.0" style="-fx-background-color: #00c6ff; -fx-background-radius: 2;" />
                                 <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #003366;" text="Planning &amp; Resources" />
                              </children>
                           </HBox>

                           <HBox spacing="25.0">
                              <children>
                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                     <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Duration (hours)" />
                                        <TextField fx:id="durationField" promptText="Ex: 30" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;" />
                                     </children>
                                  </VBox>
                                 <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Course Link" />
                                       <TextField fx:id="courseLinkField" promptText="https://..." style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>

                           <VBox spacing="8.0">
                              <children>
                                 <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #344767;" text="Comments" />
                                 <TextArea fx:id="commentArea" prefRowCount="3" promptText="Additional notes..." style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" wrapText="true" />
                              </children>
                           </VBox>
                        </children>
                     </VBox>

                     <!-- Actions -->
                     <HBox alignment="CENTER_RIGHT" spacing="15.0">
                        <children>
                           <Button fx:id="submitBtn" mnemonicParsing="false" onAction="#addCourse" style="-fx-background-color: #004fb0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 35; -fx-cursor: hand; -fx-font-size: 15px;" text="💾 Add Course" />
                        </children>
                     </HBox>

                  </children>
               </VBox>
            </children>
         </VBox>
    </children>
</StackPane>
