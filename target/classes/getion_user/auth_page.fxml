<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" styleClass="root-pane" stylesheets="@auth.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.user_controller.LoginPage">
    <children>
        <!-- Background decorative elements for the modern feel -->
        <!-- Big abstract circle on the top left -->
        <Circle fill="#2464d1" layoutX="120.0" layoutY="120.0" opacity="0.4" radius="150.0" />
        
        <!-- Small cyan circle on the bottom left -->
        <Circle fill="#0dcaf0" layoutX="100.0" layoutY="550.0" opacity="0.5" radius="50.0" />
        
        <!-- Medium translucent circle on the right side -->
        <Circle fill="#1d4899" layoutX="850.0" layoutY="200.0" opacity="0.6" radius="120.0" />

        <!-- 3D-like pill shapes (Moved further to the edges so they don't block the form) -->
        <Rectangle arcHeight="60.0" arcWidth="60.0" fill="#377df0" height="60.0" layoutX="100.0" layoutY="350.0" opacity="0.7" rotate="45.0" width="160.0" />
        <Rectangle arcHeight="60.0" arcWidth="60.0" fill="#00c3ff" height="40.0" layoutX="160.0" layoutY="280.0" opacity="0.4" rotate="45.0" width="80.0" />
        
        <Rectangle arcHeight="60.0" arcWidth="60.0" fill="#295bb8" height="60.0" layoutX="-50.0" layoutY="550.0" opacity="0.8" rotate="45.0" width="160.0" />

        <!-- Centered Main Content Area -->
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Glassmorphic Login Card -->
                <VBox alignment="CENTER_LEFT" maxWidth="420.0" maxHeight="-Infinity" spacing="12.0" styleClass="login-card">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <Label styleClass="login-title" text="Login">
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </Label>
                        
                        <Label styleClass="input-label" text="Email" />
                        <TextField fx:id="emailInput" promptText="username@gmail.com" styleClass="text-input-modern" />
                        
                        <Label styleClass="input-label" text="Password">
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Label>
                        <PasswordField fx:id="passwordInput" promptText="Password" styleClass="text-input-modern" />
                        
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Hyperlink fx:id="resetPasswordLink" styleClass="forgot-password-link" text="Forgot Password?" />
                            </children>
                        </HBox>
                        
                        <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="signin-button" text="Sign in">
                            <VBox.margin>
                                <Insets bottom="15.0" top="15.0" />
                            </VBox.margin>
                        </Button>
                        
                        <HBox alignment="CENTER">
                            <children>
                                <Label styleClass="continue-with-text" text="or continue with" />
                            </children>
                        </HBox>
                        
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" styleClass="social-button" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="G" textFill="#DB4437" />
                                <Button mnemonicParsing="false" styleClass="social-button" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="git" textFill="#333333" />
                                <Button mnemonicParsing="false" styleClass="social-button" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="f" textFill="#4267B2" />
                            </children>
                            <VBox.margin>
                                <Insets bottom="15.0" top="10.0" />
                            </VBox.margin>
                        </HBox>
                        
                        <HBox alignment="CENTER">
                            <children>
                                <Hyperlink fx:id="signUpLink" styleClass="signup-link" text="Don't have an account yet? Register for free" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>

        <!-- Illustration Image positioned at the bottom right corner (Just to match target design) -->
        <ImageView fitHeight="250.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="30.0">
            <!-- Set your illustration image here in SceneBuilder -->
        </ImageView>

    </children>
</AnchorPane>
