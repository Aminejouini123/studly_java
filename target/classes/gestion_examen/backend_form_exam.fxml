<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" stylesheets="@../TEMPLATE/backend_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.exams.ExamAddController">
    <children>
        <VBox styleClass="admin-form-container" maxWidth="900.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="admin-form-section-title" text="Examination Scheduling" />
                                <Label styleClass="subtitle-text" text="Define assessment parameters, scheduling, and grading criteria." />
                            </children>
                        </VBox>
                        <Button onAction="#handleCancel" styleClass="btn-secondary" text="Discard" />
                    </children>
                </HBox>

                <Region prefHeight="10.0" />

                <!-- 1. Schedule & Context -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="SCHEDULE &amp; COURSE CONTEXT" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Exam Title" styleClass="admin-form-label" />
                                        <TextField fx:id="titleField" promptText="Final Assessment" styleClass="admin-form-input" />
                                        <Label fx:id="titleError" style="-fx-text-fill: #ef4444; -fx-font-size: 10px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" prefWidth="250.0">
                                    <children>
                                        <Label text="Selected Course" styleClass="admin-form-label" />
                                        <Label fx:id="courseNameLabel" style="-fx-font-weight: bold; -fx-text-fill: #004fb0; -fx-background-color: #EFF6FF; -fx-padding: 8 15; -fx-background-radius: 8;" text="Loading Course..." />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Examination Date" styleClass="admin-form-label" />
                                        <DatePicker fx:id="datePicker" maxWidth="Infinity" styleClass="admin-form-combo" />
                                        <Label fx:id="dateError" style="-fx-text-fill: #ef4444; -fx-font-size: 10px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Duration (Minutes)" styleClass="admin-form-label" />
                                        <TextField fx:id="durationField" promptText="90" styleClass="admin-form-input" />
                                        <Label fx:id="durationError" style="-fx-text-fill: #ef4444; -fx-font-size: 10px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 2. Grading & Difficulty -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="GRADING &amp; COMPLEXITY" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Complexity" styleClass="admin-form-label" />
                                        <ComboBox fx:id="difficultyCombo" maxWidth="Infinity" styleClass="admin-form-combo" />
                                        <Label fx:id="difficultyError" style="-fx-text-fill: #ef4444; -fx-font-size: 10px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Target Grade (0-20)" styleClass="admin-form-label" />
                                        <TextField fx:id="gradeField" promptText="10.0" styleClass="admin-form-input" />
                                        <Label fx:id="gradeError" style="-fx-text-fill: #ef4444; -fx-font-size: 10px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Status" styleClass="admin-form-label" />
                                        <ComboBox fx:id="statusCombo" maxWidth="Infinity" styleClass="admin-form-combo" />
                                        <Label fx:id="statusError" style="-fx-text-fill: #ef4444; -fx-font-size: 10px;" visible="false" managed="false" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 3. Resources -->
                <VBox styleClass="admin-form-section">
                    <children>
                        <Label text="EXAMINATION RESOURCES" styleClass="admin-form-label" />
                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Content File Path" styleClass="admin-form-label" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <TextField fx:id="fileField" HBox.hgrow="ALWAYS" styleClass="admin-form-input" />
                                                <Button onAction="#handleChooseFile" styleClass="btn-secondary" text="Browse" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Remote Evaluation Link" styleClass="admin-form-label" />
                                        <TextField fx:id="linkField" promptText="https://exam.portal.com" styleClass="admin-form-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Actions -->
                <HBox styleClass="admin-form-button-bar">
                    <children>
                        <Button onAction="#handleSave" styleClass="btn-primary" text="Schedule Examination" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
